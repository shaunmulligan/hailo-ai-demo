#!/bin/bash

DEVICE=/dev/hailo0
PIDFILE=/run/hailo/hailort_service.pid
TIMEOUT=30

log() {
  echo "[wrapper] $1"
}

# Wait for the device to appear
log "Waiting for $DEVICE..."
for i in $(seq 1 $TIMEOUT); do
  [ -e "$DEVICE" ] && break
  sleep 1
done
[ -e "$DEVICE" ] || { log "Timeout waiting for $DEVICE"; exit 1; }

# Set our env config for hailort_service
export HAILORT_LOGGER_PATH="/var/log/hailo"
export HAILO_MONITOR=1
# Start the service
log "Starting hailort_service..."
/usr/local/bin/hailort_service

# Wait for the PID file to appear
log "Waiting for PID file: $PIDFILE"
for i in $(seq 1 $TIMEOUT); do
  if [ -s "$PIDFILE" ]; then
    PID=$(cat "$PIDFILE")
    log "PID file found with PID: $PID"
    break
  fi
  sleep 1
done

if [ -z "$PID" ] || ! ps -p "$PID" > /dev/null 2>&1; then
  log "Failed to confirm process with PID $PID is running"
  exit 1
fi

# Monitor the daemon process — if it dies, we exit so supervisord can restart it
log "Monitoring process $PID..."
while true; do
  if ps -p "$PID" > /dev/null 2>&1; then
    sleep 5
  else
    log "Process $PID exited. Wrapper exiting to allow supervisord to restart."
    exit 1
  fi
done