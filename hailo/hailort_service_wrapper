#!/bin/bash

DEVICE=/dev/hailo0
PIDFILE=/run/hailo/hailort_service.pid
TIMEOUT=30

log() {
  echo "[wrapper] $1"
}

log "Waiting for $DEVICE..."
for i in $(seq 1 $TIMEOUT); do
  [ -e "$DEVICE" ] && break
  sleep 1
done
[ -e "$DEVICE" ] || { log "Timeout waiting for $DEVICE"; exit 1; }

log "Killing any existing hailort_service processes..."
pkill -f '[h]ailort_service$' || true
rm -f "$PIDFILE"

export HAILORT_LOGGER_PATH="/var/log/hailo"
export HAILO_MONITOR=1

log "Starting hailort_service..."
/usr/local/bin/hailort_service > /var/log/hailort_service.output 2>&1

log "Waiting for PID file: $PIDFILE"
for i in $(seq 1 $TIMEOUT); do
  if [ -s "$PIDFILE" ]; then
    PID=$(cat "$PIDFILE")
    if ps -p "$PID" > /dev/null 2>&1; then
      log "PID file found with live PID: $PID"
      break
    fi
  fi
  sleep 1
done

if [ -z "$PID" ] || ! ps -p "$PID" > /dev/null 2>&1; then
  log "Failed to confirm live PID"
  exit 1
fi

log "Monitoring PID $PID..."
while kill -0 "$PID" > /dev/null 2>&1; do
  sleep 5
done

echo "[wrapper] hailort_service exited. Exiting wrapper."
exit 1